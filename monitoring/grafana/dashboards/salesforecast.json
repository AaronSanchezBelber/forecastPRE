      "targets": [
        { "expr": "salesforecast_eval_rmse", "legendFormat": "eval_rmse" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Eval MAE",
      "id": 2,
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "salesforecast_eval_mae", "legendFormat": "eval_mae" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Eval R2",
      "id": 3,
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
